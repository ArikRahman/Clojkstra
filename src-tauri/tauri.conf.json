{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "clojkstra",
  "version": "0.1.0",
  "identifier": "dev.clojkstra.app",
  "build": {
    "frontendDist": "../docs",
    "devUrl": "http://localhost:8080",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run release"
  },
  "app": {
    "windows": [
      {
        "title": "Clojkstra",
        "width": 1280,
        "height": 800,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.tailwindcss.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
