;; clj-kondo configuration for Clojkstra
;; [FRAMEWORK FILE] — linter settings for ClojureScript source.
;;
;; Run with:  clj-kondo --lint src/
;; Or via bun: bunx clj-kondo --lint src/
;;
;; Reference: https://github.com/clj-kondo/clj-kondo/blob/master/doc/config.md

{:lint-as
 {;; Treat re-frame registration macros as def-like forms so clj-kondo
  ;; understands that the symbol is "used" even if only referenced via
  ;; dispatch/subscribe keywords.
  re-frame.core/reg-event-db clj-kondo.lint-as/def-catch-all
  re-frame.core/reg-event-fx clj-kondo.lint-as/def-catch-all
  re-frame.core/reg-sub      clj-kondo.lint-as/def-catch-all
  re-frame.core/reg-fx       clj-kondo.lint-as/def-catch-all
  re-frame.core/reg-cofx     clj-kondo.lint-as/def-catch-all}

 :linters
 {;; Warn on unused bindings — catches dead let-bindings and destructuring.
  :unused-binding        {:level :warning}

  ;; Warn on unused imports / requires.
  :unused-namespace      {:level :warning}
  :unused-referred-var   {:level :warning}

  ;; Warn on redefined vars — usually a copy/paste mistake.
  :redefined-var         {:level :warning}

  ;; Error on mismatched arity calls — catches calling a 2-arg fn with 3 args.
  :invalid-arity         {:level :error}

  ;; Warn when a private var is used outside its defining namespace.
  :private-call          {:level :warning}

  ;; Warn on use of deprecated vars.
  :deprecated-var        {:level :warning}

  ;; Allow the idiomatic (ns ...) form without triggering namespace warnings.
  :misplaced-docstring   {:level :warning}

  ;; Disable the "unused-value" warning for top-level side-effectful forms
  ;; like (rf/reg-event-db ...) — their return value is intentionally ignored.
  :unused-value          {:level :off}

  ;; Tolerate (comment ...) blocks — common in Clojure for scratch code.
  :unused-private-var    {:level :warning}}

 ;; ---------------------------------------------------------------------------
 ;; Namespace-level overrides
 ;; Use :exclude to silence a specific linter in a specific file, e.g.:
 ;;
 ;; :config-in-ns
 ;; {clojkstra.app.effects
 ;;  {:linters {:unused-binding {:level :off}}}}
 ;; ---------------------------------------------------------------------------

 :config-in-ns {}

 ;; ---------------------------------------------------------------------------
 ;; Output
 ;; ---------------------------------------------------------------------------
 :output
 {:format        :text   ; :text | :json | :edn
  :include-files true    ; show the filename in every finding
  :canonical-paths true}}
