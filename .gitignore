# =============================================================================
# Clojkstra .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Tauri / Rust build artefacts
# ---------------------------------------------------------------------------
src-tauri/target/
# Generated by Cargo
# will have compiled files and executables

src-tauri/gen/schemas

# ---------------------------------------------------------------------------
# ClojureScript / shadow-cljs build artefacts
# ---------------------------------------------------------------------------
.shadow-cljs/
.cljs_node_repl/
out/
target/
classes/

# shadow-cljs build report
report.html

# ---------------------------------------------------------------------------
# Compiled output — keep docs/ tracked (GitHub Pages source)
# but ignore the generated JS bundle inside it
# ---------------------------------------------------------------------------
docs/cljs-out/cljs-runtime

# ---------------------------------------------------------------------------
# Bun / Node package manager
# ---------------------------------------------------------------------------
node_modules/
bun.lockb
.bun/

# ---------------------------------------------------------------------------
# Java / Clojure tooling
# ---------------------------------------------------------------------------
.cpcache/
.lein-repl-history
.nrepl-port
.nrepl-history
*.class
pom.xml
pom.xml.asc

# ---------------------------------------------------------------------------
# Editor and IDE artefacts
# ---------------------------------------------------------------------------

# Emacs
*~
\#*\#
.\#*
*.elc
.dir-locals.el

# VS Code
.vscode/
*.code-workspace

# IntelliJ / Cursive
.idea/
*.iml
*.ipr
*.iws

# Vim / Neovim
*.swp
*.swo
*.swn
.vim/
Session.vim

# ---------------------------------------------------------------------------
# OS artefacts
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
Desktop.ini

# ---------------------------------------------------------------------------
# Nix
# ---------------------------------------------------------------------------
result
result-*

# ---------------------------------------------------------------------------
# Environment / secrets — NEVER commit these
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
secrets.edn
config.local.edn

# ---------------------------------------------------------------------------
# Logs and temp files
# ---------------------------------------------------------------------------
*.log
*.tmp
*.temp
.clj-kondo
npm-debug.log*
bun-debug.log*
