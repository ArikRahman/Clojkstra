{
  "name": "clojkstra",
  "version": "0.1.0",
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadow-cljs": "^3.3.6"
  },
  "description": "Clojkstra – ClojureScript + re-frame starter template",
  "packageManager": "bun@1.3.10",
  "private": true,
  "scripts": {
    "dev": "bunx shadow-cljs watch app",
    "release": "bunx shadow-cljs release app",
    "clean": "rm -rf docs/cljs-out .shadow-cljs",
    "report": "bunx shadow-cljs run shadow.cljs.build-report app report.html"
  }
}
